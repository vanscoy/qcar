def get_pose(car):
    try:
        ok, pos, rpy, _scale = car.get_world_transform()
        if not ok:
            return None
        return float(pos[0]), float(pos[1]), float(rpy[2])
    except Exception:
        return None

# -----------------------------
# Helpers: planner
# -----------------------------
def coord_of(node: str):
    if node not in NODES:
        raise ValueError(f"Unknown node '{node}' (missing from NODES)")
    return NODES[node]

def dist_xy(u: str, v: str) -> float:
    ux, uy, _ = coord_of(u)
    vx, vy, _ = coord_of(v)
    return math.hypot(vx - ux, vy - uy)

def build_graph(raw_edges):
    nodes = set()
    for u, v, _ in raw_edges:
        nodes.add(u)
        nodes.add(v)

    graph = {n: [] for n in nodes}
    for u, v, mode in raw_edges:
        w = dist_xy(u, v)
        graph[u].append((v, w, mode))
    return graph

def dijkstra(graph, start, goal):
    pq = [(0.0, start)]
    best = {start: 0.0}
    parent = {start: None}
    parent_edge = {start: None}

    while pq:
        g, u = heappop(pq)
        if g != best.get(u, float("inf")):
            continue
        if u == goal:
            break
        for v, w, mode in graph.get(u, []):
            ng = g + w
            if ng < best.get(v, float("inf")):
                best[v] = ng
                parent[v] = u
                parent_edge[v] = (u, v, mode, w)
                heappush(pq, (ng, v))

    if goal not in best:
        return None, float("inf"), None

    path, steps = [], []
    cur = goal
    while cur is not None:
        path.append(cur)
        e = parent_edge[cur]
        if e is not None:
            steps.append(e)
        cur = parent[cur]
    path.reverse()
    steps.reverse()
    return path, best[goal], steps

def plan_full_route(graph, pickup, dropoff):
    legs = [("HUB", pickup), (pickup, dropoff), (dropoff, "HUB")]

    full_nodes = []
    full_modes = []

    for i, (s, t) in enumerate(legs):
        path, _cost, steps = dijkstra(graph, s, t)
        if path is None:
            raise RuntimeError(f"No path from {s} to {t}")

        if i == 0:
            full_nodes += path
        else:
            full_nodes += path[1:]

        full_modes += [mode for (_u, _v, mode, _w) in steps]

    if len(full_modes) != max(0, len(full_nodes) - 1):
        raise RuntimeError(f"planner mismatch: modes={len(full_modes)} nodes={len(full_nodes)}")

    return full_nodes, full_modes

def ask_pick_drop(graph):
