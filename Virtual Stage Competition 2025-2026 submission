def ensure_bgr(frame):
    global SOURCE_IS_RGB
    if frame is None:
        return None
    if SOURCE_IS_RGB:
        return cv2.cvtColor(frame, cv2.COLOR_RGB2BGR)
    return frame

def apply_roi(img_bgr, y_start_frac):
    h, w = img_bgr.shape[:2]
    y0 = int(np.clip(h * y_start_frac, 0, h - 1))
    return img_bgr[y0:h, :], (0, y0)

# -----------------------------
# WHITE follower
# -----------------------------
def crop_right_half(roi_bgr, start_frac=0.5):
    h, w = roi_bgr.shape[:2]
    x0 = int(np.clip(w * start_frac, 0, w - 1))
    return roi_bgr[:, x0:w], x0

def make_white_mask(roi_bgr):
    hsv = cv2.cvtColor(roi_bgr, cv2.COLOR_BGR2HSV)
    _, S, V = cv2.split(hsv)
    wmask = ((S <= W_S_MAX) & (V >= W_V_MIN)).astype(np.uint8) * 255
    k = cv2.getStructuringElement(cv2.MORPH_RECT, (2, 2))
    wmask = cv2.morphologyEx(wmask, cv2.MORPH_OPEN, k, iterations=1)
    return wmask

def pick_leftmost_contour(wmask, debug_img=None):
    cnts, _ = cv2.findContours(wmask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
    if not cnts:
        return None, {"found": False, "reason": "No contours"}

    best = None
    best_cx = 1e18
    rejects = {"short": 0, "wide": 0, "moments": 0}

    for c in cnts:
        x, y, bw, bh = cv2.boundingRect(c)
        if bh < LEN_MIN:
            rejects["short"] += 1
            continue
        if bw > WIDTH_MAX:
            rejects["wide"] += 1
            continue
        M = cv2.moments(c)
        if M["m00"] <= 0:
            rejects["moments"] += 1
            continue
        cx = float(M["m10"] / M["m00"])
        cy = float(M["m01"] / M["m00"])
        if cx < best_cx:
            best_cx = cx
            best = (c, cx, cy, x, y, bw, bh)

    if best is None:
        return None, {
            "found": False,
            "reason": f"Rejected all | short:{rejects['short']} wide:{rejects['wide']} mom:{rejects['moments']}"
        }

    c, cx, cy, x, y, bw, bh = best
    if debug_img is not None:
        cv2.drawContours(debug_img, [c], -1, (0, 255, 255), 2)
        cv2.rectangle(debug_img, (x, y), (x + bw, y + bh), (255, 0, 0), 2)
        cv2.circle(debug_img, (int(cx), int(cy)), 6, (0, 255, 0), -1)

    return {"centroid": (cx, cy), "bbox": (x, y, bw, bh)}, {"found": True, "reason": "OK"}

def white_follow_step(img_bgr):
    roi_bgr, (x_off, y_off) = apply_roi(img_bgr, W_ROI_START_FRAC)
    roi_r_bgr, x_r_off = crop_right_half(roi_bgr, RIGHT_HALF_START_FRAC)
    wmask = make_white_mask(roi_r_bgr)

    debug = roi_r_bgr.copy()
    pick, info = pick_leftmost_contour(wmask, debug_img=debug)

    hR, wR = wmask.shape[:2]
    target_x = float(max(0, wR - W_TARGET_FROM_RIGHT_PX))

    turn = 0.0
    found = False
    status = f"NO | {info['reason']}"

    if pick is not None:
        found = True
        cx, cy = pick["centroid"]
        err = target_x - cx
        turn = -err * W_STEER_GAIN
        turn = float(np.clip(turn, -STEER_CLIP, STEER_CLIP))
        cv2.circle(
            debug,
            (int(np.clip(target_x, 0, wR - 1)), int(np.clip(cy, 0, hR - 1))),
            7, (255, 255, 255), -1
        )
        x, y, bw, bh = pick["bbox"]
        status = f"FOUND | cx={cx:.1f} len={bh}px wid={bw}px err={err:+.1f} turn={turn:+.3f}"

    overlay = img_bgr.copy()
    rh, rw = debug.shape[:2]
    full_x0 = x_off + x_r_off
    full_y0 = y_off
    overlay[full_y0:full_y0 + rh, full_x0:full_x0 + rw] = debug
    cv2.rectangle(overlay, (full_x0, full_y0), (full_x0 + rw - 1, full_y0 + rh - 1), (0, 255, 0), 2)

    return turn, overlay, wmask, status, found

